<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Menu_SectionName">Steam Collection Importer</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Menu_ImportCollectionsForAllGames">Import collections for all games</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Menu_ImportCollectionsForFilteredGames">Import collections for filtered games</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Menu_ImportCollectionsForSelectedGames">Import collections for selected games</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Menu_ImportCollections">Import collections</sys:String>

    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Confirmation">
        Are you sure you want to import collections from Steam?

        This operation WILL overwrite categories in affected games!

        Dynamic collections will not be imported.
    </sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Done">Done!</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_AddedNumberOfCollections">Added {0} collections!</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_ChangedNumberOfGames">Changed {0} games!</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_NoChanges">No changes found.</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_Error">Error occurred while importing collections!</sys:String>
    <sys:String x:Key="LOC_Yalgrin_SteamCollectionImporter_NoSteamLibrary">Failed to import collections, no Steam library plugin found!</sys:String>

</ResourceDictionary>